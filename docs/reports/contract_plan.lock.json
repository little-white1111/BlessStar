{
  "version": "v1",
  "index_file": "docs/contracts/index.json",
  "gate_registry_file": "docs/gates/gate_registry.json",
  "repository_layout": {
    "gate_registry": "docs/gates/gate_registry.json",
    "lock_plan_output": "docs/reports/contract_plan.lock.json",
    "gate_report_output": "docs/reports/contract-gate-report.json",
    "compile_entry": "tools/scripts/contracts/contract_compile.py",
    "gate_runner_entry": "tools/scripts/contracts/contract_gate_runner.py",
    "validate_instances_entry": "tools/scripts/contracts/contract_validate_instances.py"
  },
  "script_layout": {
    "python_gate": "tools/scripts/gates/",
    "orchestration": "tools/scripts/contracts/",
    "format": "tools/scripts/format/",
    "maintenance": "tools/scripts/maintenance/",
    "perf": "tools/scripts/perf/",
    "shared_lib": "tools/scripts/lib/",
    "purity": "tools/purity/",
    "app_vendor_plugins": "app/sdk/vendor/"
  },
  "add_gate_workflow": [
    "Read governance_tiers in this file: pick implementation tier (script vs ctest vs runtime-indirect) before adding a gate.",
    "Add verifier script under script_layout.python_gate (python) or register a ctest command in gate_registry (ctest).",
    "Register the gate in repository_layout.gate_registry with gate_id, stage, runner, command, covers.",
    "On each contract instance: set gate_refs[] and implementations[] (one entry per gate_id; entry_kind script|command).",
    "Run: python tools/scripts/contracts/contract_validate_instances.py",
    "Run: python tools/scripts/contracts/contract_compile.py",
    "Run: python tools/scripts/contracts/contract_gate_runner.py"
  ],
  "policy": {
    "fail_fast": true,
    "draft_policy": "warn",
    "report_dir": "docs/reports"
  },
  "priority_order": [
    "architecture",
    "kernel",
    "integration",
    "style",
    "functional",
    "configuration",
    "testing"
  ],
  "stage_order": [
    "preflight",
    "bootstrap",
    "freeze",
    "read",
    "parse",
    "ir_gate",
    "persist",
    "watch",
    "ci",
    "dev_ci",
    "staging",
    "prod_ops"
  ],
