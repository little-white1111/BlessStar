# ═══════════════════════════════════════════════════════════════════════
#  BlessStar — Whitelist .gitignore
#  Only core directories and files listed below will be tracked.
#  Everything else is ignored by default.
# ═══════════════════════════════════════════════════════════════════════

# ── Ignore everything by default (whitelist approach) ──
/*

# ── Core directories ────────────────────────────────────────────────
!/kernel/
!/adapter/
!/app/
!/tools/
!/cmake/

# ── Root-level files ────────────────────────────────────────────────
!/.clang-format
!/.gitattributes
!.gitignore
!/.github/
!/CMakeLists.txt
!/CMakePresets.json
!/README.md
!/config_v1_golden.h

# ── OS / editor debris ──────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
.vscode/
.idea/
.cursor/
.trae/
.traecli/

# ── Agent collaboration notes (local) ───────────────────────────────
一主二子agent模式搭建.md
三智能体提示词.txt

# ── Build artifacts (anywhere) ──────────────────────────────────────
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Makefile
compile_commands.json
install_manifest.txt
meson-private/
meson-logs/
meson-info/
.mesonpy-*
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.pdb
*.ilk
*.exp
*.gcda
*.gcno
*.gcov

# ── Node / npm / Electron build ─────────────────────────────────────
node_modules/
app/editor/build/
app/editor/dist/
app/editor/dist-electron/
app/editor/release/
app/editor/.electron-cache/
app/editor/dist-renderer/
app/editor/dist.asar
app/editor/build-output/
app/editor/=
app/editor/native/target/
app/editor/native/*.node
app/editor/native/build_err*.txt

# ── Editor temp / debug files ──────────────────────────────────────
app/editor/._*
app/editor/_*.cjs
app/editor/_*.mjs
app/editor/*.txt
app/editor/.api-check.json
app/editor/.batch-ai-test-report.json
app/editor/.final-test-report.json
app/editor/asar_*.txt
app/editor/batch-ai-test*.mjs
app/editor/cli-ai.mjs
app/editor/test-cli.mjs
app/editor/test-write.json
app/editor/check-report.js
app/editor/update-asar.ps1

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
coverage/

# ── Logs (anywhere) ─────────────────────────────────────────────────
*.log

# ── Reference sources (local only) ──────────────────────────────────
Source/

# ── Local secrets ───────────────────────────────────────────────────
tools/ci/.github_token

# ── CI logs (anywhere under tools/) ────────────────────────────────
tools/ci/logs/

# ── Generated build tooling ────────────────────────────────────────
tools/build/

# ── Local scratch / IO test debris ──────────────────────────────────
test.txt
bs_io_*.txt
